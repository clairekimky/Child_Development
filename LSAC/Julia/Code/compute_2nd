#(1) Use only 1000 iterations to get better guesses of the parameters

function objective_function(params1c, params1n, params_all, df_matrix)
    
    rng = MersenneTwister(1234) # Fixed seed for current iteration to ensure each optimizer iteration gets consistent random draws, but still reflects changes in parameters
    # Call the Calibrate function, passing the parameters (which are now constrained)
    return Calibrate(rng, params1c, params1n, params_all, df_matrix)
end

function objective_function_w(params1c, params1n, params_all, df_matrix)
    
    rng = MersenneTwister(1234) # Fixed seed for current iteration to ensure each optimizer iteration gets consistent random draws, but still reflects changes in parameters
    # Call the Calibrate function, passing the parameters (which are now constrained)
    return Calibrate_w(rng, params1c, params1n, params_all, df_matrix)
end

