function moment_conditions_cog_CRE(params, df)
    groups = [1, 2, 3]
    all_moments = []

    # Precompute child averages (CRE)
    child_ids = unique(df[:,1])
    avg_dict = Dict{Int, Vector{Float64}}()
    for id in child_ids
        rows = findall(df[:,1] .== id)
        avg_vals = Float64[]
        for col in [7, 10, 3, 11]  # z, tau, M, hyp
            valid_rows = [r for r in rows if df[r,col] > 0]
            push!(avg_vals, isempty(valid_rows) ? 0.0 : mean(log.(df[valid_rows, col])))
        end
        avg_dict[id] = [v <= 0 ? 1e-8 : v for v in avg_vals]
    end

    for (i, group) in enumerate(groups)
        valid_rows = filter(row -> row[2]==group &&
            row[3] > 0 && row[4] > 0 &&
            row[7] > 0 && row[8] > 0 &&
            row[9] > 0 && row[10] > 0 &&
            row[11] > 0, eachrow(df))

        if isempty(valid_rows)
            continue
        end

        # Current observations
        z_f     = [row[4] for row in valid_rows]
        z       = [row[7] for row in valid_rows]
        tau = [row[10] for row in valid_rows]
        M   = [row[3] for row in valid_rows]
        hyp     = [row[11] for row in valid_rows]

        # Instruments
        inst1 = [row[8] for row in valid_rows]
        inst2 = [row[9] for row in valid_rows]
        instruments = hcat(inst1, inst2)

        # Child averages
        child_avg = [avg_dict[row[1]] for row in valid_rows]
        avg_matrix = hcat(child_avg...)'  # Nx4

        # Fitted values: ln_A + δ*current + γ*child_avg
        fitted = params[1+5*(i-1)] .+
         params[2+5*(i-1)] .* log.(z) .+
         params[3+5*(i-1)] .* log.(tau) .+   # only if log_tau is strictly positive
         params[4+5*(i-1)] .* log.(M) .+     # M column
         params[5+5*(i-1)] .* log.(hyp) .+       # hyp column
         params[16] .* (avg_matrix[:,1]) .+
         params[17] .* (avg_matrix[:,2]) .+
         params[18] .* (avg_matrix[:,3]) .+
         params[19] .* (avg_matrix[:,4])

        residuals = log.(z_f) .- fitted

        # Moments: residuals times instruments
        moments = hcat([residuals .* instruments[:,j] for j in 1:size(instruments,2)]...)
        push!(all_moments, moments)
    end

    return vcat(all_moments...)
end

function gmm_objective(params, data)
    m = moment_conditions_cog_CRE(params, data)
    g = vec(mean(m, dims=1))
    return dot(g,g)  # Identity weighting
end

function compute_optimal_weight_matrix(params, data)
    m = moment_conditions_cog_CRE(params, data)
    g = m .- mean(m, dims=1)
    W = (g' * g) / size(g,1)
    return inv(W)
end

function gmm_objective_weighted(params, data, W)
    m = moment_conditions_cog_CRE(params, data)
    g = vec(mean(m, dims=1))
    return g' * W * g
end

# Step 1: First-step GMM
res_step1 = Optim.optimize(p -> gmm_objective(p, df_matrix1), params1_CRE, BFGS())
params_step1 = Optim.minimizer(res_step1)

# Step 2: Optimal weighting matrix
W_opt = compute_optimal_weight_matrix(params_step1, df_matrix1)

# Step 3: Efficient GMM
res_step2 = Optim.optimize(p -> gmm_objective_weighted(p, df_matrix1, W_opt), params_step1, BFGS())
params_step2 = Optim.minimizer(res_step2)

num_bootstrap = 100
param_boot = zeros(num_bootstrap, length(params1_CRE))
child_ids = unique(df_matrix1[:,1])
H = length(child_ids)

for b in 1:num_bootstrap
    if b % 10 == 0
        println("Bootstrap iteration $b / $num_bootstrap")
    end

    sampled_ids = sample(child_ids, H, replace=true)
    df_b = vcat([df_matrix1[df_matrix1[:,1] .== id, :] for id in sampled_ids]...)

    try
        res1 = Optim.optimize(p -> gmm_objective(p, df_b), params1_CRE, BFGS()) # Start each bootstrap iteration from my original starting point
        params_step1_b = Optim.minimizer(res1)

        W_b = compute_optimal_weight_matrix(params_step1_b, df_b)
        res2 = Optim.optimize(p -> gmm_objective_weighted(p, df_b, W_b), params_step1_b, BFGS())
        param_boot[b,:] .= Optim.minimizer(res2)

    catch e
        println("Bootstrap iteration $b failed: ", e)
        param_boot[b,:] .= NaN
    end
end

# Filter successful samples
