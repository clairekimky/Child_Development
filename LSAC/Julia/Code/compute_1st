for b in 1:num_bootstrap
    if b % 10 == 0
        println("Bootstrap iteration $b / $num_bootstrap")
    end

    sampled_ids = sample(child_ids, H, replace=true)
    df_b = vcat([df_matrix1[df_matrix1[:,1] .== id, :] for id in sampled_ids]...)

    try
        res1 = Optim.optimize(p -> gmm_objective(p, df_b), params1_CRE, BFGS()) # Start each bootstrap iteration from my original starting point
        params_step1_b = Optim.minimizer(res1)

        W_b = compute_optimal_weight_matrix(params_step1_b, df_b)
        res2 = Optim.optimize(p -> gmm_objective_weighted(p, df_b, W_b), params_step1_b, BFGS())
        param_boot[b,:] .= Optim.minimizer(res2)

    catch e
        println("Bootstrap iteration $b failed: ", e)
        param_boot[b,:] .= NaN
    end
end

