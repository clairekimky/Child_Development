function moment_conditions_cog(params1, df_matrix1; return_residuals=false)
    groups = [1, 2, 3]
    all_moments = []
    residual_list = []

    #μ_0, μ_1 = factor(df_matrix1, n_age)

    for (i, group) in enumerate(groups)
        # Filter valid rows
        valid_rows = filter(row -> row[2] == group && row[3] > 0 && 
                                       row[10] > 0 && row[11] != -999, eachrow(df_matrix1))

        if length(valid_rows) == 0
            continue
        end

        # Extract variables
        z_f = log.([row[4] for row in valid_rows])                      # future proxy (θ_{j,t+1})
        z = log.([row[7] for row in valid_rows])              # current proxy (θ_{j,t})
        log_tau = log.([row[10] for row in valid_rows])               # log(τ_{c,t})
        log_M = log.([row[3] for row in valid_rows])                  # log(M_t)
        hyp = log.([row[11] for row in valid_rows])

        # Rescale proxies
        #z_f_tilde = (z_f .- μ_0[1, i]) ./ μ_1[1, i]
        #z_tilde = (z .- μ_0[1, i]) ./ μ_1[1, i]

        # Instruments: lagged alternate proxies (assumed uncorrelated measurement errors)
        inst1 = log.([row[8] for row in valid_rows])
        inst2 = log.([row[9] for row in valid_rows])
        instruments = hcat(inst1, inst2)

        # Parameter block for group
        offset = (i - 1) * 5
        ln_A = params1[offset + 1]
        δ1 = params1[offset + 2]
        δ2 = params1[offset + 3]
        δ3 = params1[offset + 4]
        δ4 = params1[offset + 5]

        # Predicted values
        fitted = ln_A .+ δ1 .* z .+ δ2 .* log_tau .+ δ3 .* log_M .+ δ4 .* hyp
        residuals = z_f .- fitted
        residual_list = vcat(residual_list, residuals)

        moments = hcat([residuals .* instruments[:, j] for j in 1:size(instruments, 2)]...)
        push!(all_moments, moments)
    end

    if return_residuals
        return vcat(all_moments...), residual_list
    else
        return vcat(all_moments...)
    end
end

function gmm_objective(params, data)
    m = moment_conditions_cog(params, data)
    g = vec(mean(m, dims=1))
    return dot(g, g)  # Simple GMM with identity weighting matrix
end

res_step1 = optimize(
    p -> gmm_objective(p, df_matrix1),
    params1,
    LBFGS()
)
params_step1 = Optim.minimizer(res_step1)

function compute_optimal_weight_matrix(params, data)
    m = moment_conditions_cog(params, data)
    g = m .- mean(m, dims=1)  # center the moment conditions
    W = (g' * g) / size(g, 1)  # covariance of moment conditions
    return inv(W)
end

function gmm_objective_weighted(params, data, W)
    m = moment_conditions_cog(params, data)
    g = vec(mean(m, dims=1))
    return g' * W * g
end

W_opt = compute_optimal_weight_matrix(params_step1, df_matrix1)

res_step2 = optimize(
    p -> gmm_objective_weighted(p, df_matrix1, W_opt),
    params_step1,
    LBFGS()
)

params_step2 = Optim.minimizer(res_step2)

println(params_step2)

# Bootstrapped CI
num_bootstrap = 100  # Number of bootstrap repetitions
param_boot = zeros(num_bootstrap, length(params1))

# Get unique household IDs
household_ids = unique(df_matrix1[:, 1])
H = length(household_ids)

for b in 1:num_bootstrap

    # Print progress every 10 iterations
    if b % 10 == 0
        println("Bootstrap iteration $b / $num_bootstrap")
    end

    # Resample household IDs with replacement
    sampled_ids = sample(household_ids, H, replace=true)
    
    # Print sampled household IDs for debugging
    #println("Bootstrap iteration $b: Sampled IDs = ", sampled_ids)
    
    # Build resampled dataframe
    df_b = vcat([
        df_matrix1[df_matrix1[:, 1] .== hh, :] for hh in sampled_ids
    ]...)

    # Try-catch in case optimization fails
    try
        # Step 1: First-step GMM with identity matrix
        res1 = optimize(
            p -> gmm_objective(p, df_b),
            params1,
            LBFGS()
        )
        params_step1_b = Optim.minimizer(res1)
    
        # Step 2: Compute optimal weighting matrix using first-step parameters
        W_b = compute_optimal_weight_matrix(params_step1_b, df_b)
    
        # Step 3: Second-step GMM using optimal weighting
        res2 = optimize(
            p -> gmm_objective_weighted(p, df_b, W_b),
            params_step1_b,
            LBFGS()
        )
        param_boot[b, :] .= Optim.minimizer(res2)
    
    catch e
        println("Bootstrap iteration $b failed: ", e)
        param_boot[b, :] .= NaN
    end
    
end

# Filter successful bootstrap samples
valid_rows = findall(row -> all(.!isnan.(row)), eachrow(param_boot))
param_boot_clean = param_boot[valid_rows, :]

# 95% confidence intervals
ci_lower = mapslices(p -> quantile(p, 0.025), param_boot_clean; dims=1)
ci_upper = mapslices(p -> quantile(p, 0.975), param_boot_clean; dims=1)

# Combine into readable output
confidence_intervals = hcat(ci_lower', ci_upper')  # Each row: [lower upper] for a param

# Display
for (i, ci) in enumerate(eachrow(confidence_intervals))
    println("Param $i: 95% CI = [", round(ci[1], digits=4), ", ", round(ci[2], digits=4), "]")
end

