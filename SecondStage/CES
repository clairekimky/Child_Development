# Define TFP terms
function TFP(ψ, data::DataFrame)
    n = length(unique(data.pid))
    # Initialize TFP terms
    A_c = zeros(Float64, n, 3)
    A_b = zeros(Float64, n, 3)

    # Precompute the valid indices
    valid_indices = [data[(i - 1) * 3 + 1] != -999 for i in 1:n] # n X 1 Array

    for i in 1:n
        for t in 1:3
            if valid_indices[(i - 1) * t + 1]
                A_c[i, t] = exp(ψ0_c[t] + x * ψ_c[t] + ν_c) 
                A_b[i, t] = exp(ψ0_b[t] + x * ψ_b[t] + ν_b)
            end
        end
    end

    return A_c, A_b 
end

