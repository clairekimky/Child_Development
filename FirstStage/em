function normpdf(μ, σ, x)
    pdf = (1 / sqrt(2 * pi * σ^2)) * exp(-(x - μ)^2 / (2 * σ^2))

    return pdf
end

function generate_invertible_matrix()
    A = randn(6, 6)  # Generate a 2x2 matrix with random elements between 0 and 1
    while det(A) ≈ 0.0  # Check if the determinant is approximately zero
        A = randn(6, 6)  # If the matrix is singular, generate a new random matrix
    end
    return A
end

function is_not_positive_definite(Δ::AbstractMatrix)
    try
        cholesky(Δ)
        return false
    catch
        return true
    end
end

function ensure_positive_definite!(Δ::AbstractMatrix; tol::Float64=1e-6)
    max_iters = 100
    perturbation = 1e-3
    iter = 0
    
    while is_not_positive_definite(Δ) && iter < max_iters
        Δ .+= perturbation * Diagonal(I, size(Δ, 1))
        
        # Adjust diagonal elements if necessary
        for k in 1:size(Δ, 1)
            if Δ[k, k] <= 0
                Δ[k, k] = abs(Δ[k, k]) + tol
            end
        end
        
        # Check positive definiteness based on eigenvalues
        if is_not_positive_definite(Δ)
            min_eigenvalue = minimum(eigen(Δ).values)
            Δ .+= max(abs(min_eigenvalue), tol) * Diagonal(I, size(Δ, 1))
        end
        
        perturbation *= 2  # Increase perturbation for next iteration
        iter += 1
    end
    
    if iter == max_iters
        error("Unable to make the matrix positive definite after $max_iters iterations.")
    end
end

