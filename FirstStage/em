    for b in 1:num_bootstraps
        # Generate bootstrap sample
        bootstrap_indices = rand(1:n, n)  # Sample with replacement
        bootstrap_data = data[bootstrap_indices, :]

        # EM algorithm on bootstrap sample
        k1_b = copy(k1)
        k2_b = copy(k2)
        #k3_b = copy(k3)
        #k4_b = copy(k4)
