        end

        # Store the estimated parameters for the bootstrap sample
        #Ψ_bootstrap = [k1_b; k2_b; k3_b; k4_b; vec(Δ1_b); vec(Δ2_b); vec(Δ3_b); vec(Δ4_b); κ_b]
        Ψ_bootstrap = [k1_b; k2_b; vec(Δ1_b); vec(Δ2_b); κ_b; μ; α; σ]
        bootstrapped_params[:, b] = Ψ_bootstrap
    end

    return bootstrapped_params
end

# Compute Bootstrapped Standard Errors and Final Parameters
function compute_final_estimates_and_standard_errors(k1, Δ1, k2, Δ2, κ, μ, α, σ, R, data, num_bootstraps::Int, max_iters)
    num_params = 149    # Number of parameters
    # Estimate parameters on the original data
    #k1_fin, Δ1_fin, k2_fin, Δ2_fin, k3_fin, Δ3_fin, k4_fin, Δ4_fin, κ_fin = em_algorithm(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data; max_iters)
    k1_fin, Δ1_fin, k2_fin, Δ2_fin, κ_fin, μ, α, σ = em_algorithm(k1, Δ1, k2, Δ2, κ, μ, α, σ, R, data; max_iters)
    
    # Compute bootstrapped parameters
    #bootstrapped_params = bootstrap_em(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data, num_bootstraps, max_iters)
    bootstrapped_params = bootstrap_em(k1_fin, Δ1_fin, k2_fin, Δ2_fin, κ_fin, μ, α, σ, R, data, num_bootstraps, max_iters)

    # Compute standard errors
    #std_errors = std(bootstrapped_params, dims=2)

    # Compute Confidence Intervals
    alpha = 0.1  # 90% confidence interval
    lower_percentile = 100 * alpha / 2
    upper_percentile = 100 * (1 - alpha / 2)
    confidence_intervals = zeros(num_params, 2)

    for i in 1:num_params
        sorted_params = sort(bootstrapped_params[i, :])
        confidence_intervals[i, 1] = sorted_params[round(Int, lower_percentile * num_bootstraps / 100)]
        confidence_intervals[i, 2] = sorted_params[round(Int, upper_percentile * num_bootstraps / 100)]
    end    

    # Combine final estimates and standard errors in a dictionary for easy access
    #final_estimates = [k1_fin; k2_fin; k3_fin; k4_fin; vec(Δ1_fin); vec(Δ2_fin); vec(Δ3_fin); vec(Δ4_fin); κ_fin]
    final_estimates = [k1_fin; k2_fin; vec(Δ1_fin); vec(Δ2_fin); κ_fin; μ; α; σ]
    results = Dict(
        "Final Estimates" => final_estimates,
    #    "Standard Errors" => std_errors,
        "Confidence Intervals" => confidence_intervals
    )

    return results
end

# Compute the Signal to Noise Ratio
function noise(α, σ, θ)
    J = 21 # The number of measures

    s = zeros(J)
    
    for j in 1:J
        if j in 1:3 # cognitions
            s[j] = α[j]^2 * var(θ[:, 1]) / (α[j]^2 * var(θ[:, 1]) + σ[j]^2)
        elseif j in 4:6 # cognitions
            s[j] = α[j]^2 * var(θ[:, 2]) / (α[j]^2 * var(θ[:, 2]) + σ[j]^2)
        elseif j in 7:9 # cognitions
            s[j] = α[j]^2 * var(θ[:, 3]) / (α[j]^2 * var(θ[:, 3]) + σ[j]^2)
        elseif j in 10:13 # gender role
            s[j] = α[j]^2 * var(θ[:, 4]) / (α[j]^2 * var(θ[:, 4]) + σ[j]^2)
        elseif j in 14:17 # gender role
            s[j] = α[j]^2 * var(θ[:, 5]) / (α[j]^2 * var(θ[:, 5]) + σ[j]^2)
        elseif j in 18:21 # gender role
            s[j] = α[j]^2 * var(θ[:, 6]) / (α[j]^2 * var(θ[:, 6]) + σ[j]^2)
        end
    end

    return s
end
