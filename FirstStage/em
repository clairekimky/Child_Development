# EM algorithm
function em_algorithm(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data::DataFrame; max_iters)
    
    for iter in 1:max_iters
        # Draw latent factors
        θ = draw_samples_positive(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data) ## n by R by 2 array

        # E-step
        println("Starting E-step iteration $iter")
        posterior = expectation_step_n(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, θ, R, data)
        println("Completed E-step iteration $iter")
        
        # M-step
        println("Starting M-step iteration $iter")
        k1_new, k2_new, k3_new, k4_new, Δ1_new, Δ2_new, Δ3_new, Δ4_new, κ_new = m_step(posterior, θ, R, data)
        println("Completed M-step iteration $iter")
        
        # Check convergence
        κ_change = norm(κ_new - κ) / max(norm(κ), 1e-6)
        k1_change = norm(k1_new - k1) / max(norm(k1), 1e-6)
        k2_change = norm(k2_new - k2) / max(norm(k2), 1e-6)
        k3_change = norm(k3_new - k3) / max(norm(k3), 1e-6)
        k4_change = norm(k4_new - k4) / max(norm(k4), 1e-6)
        Δ1_change = norm(Δ1_new - Δ1) / max(norm(Δ1), 1e-6)
        Δ2_change = norm(Δ2_new - Δ2) / max(norm(Δ2), 1e-6)
        Δ3_change = norm(Δ3_new - Δ3) / max(norm(Δ3), 1e-6)
        Δ4_change = norm(Δ4_new - Δ4) / max(norm(Δ4), 1e-6)
        
        # Check if all changes are below the convergence threshold
        if κ_change < 0.001 && k1_change < 0.001 && k2_change < 0.001 && k3_change < 0.001 && k4_change < 0.001 && Δ1_change < 0.001 && Δ2_change < 0.001 && Δ3_change < 0.001 && Δ4_change < 0.001
            println("Converged after $iter iterations.")
            break
        end
    
        k1, k2, k3, k4, Δ1, Δ2, Δ3, Δ4, κ = k1_new, k2_new, k3_new, k4_new, Δ1_new, Δ2_new, Δ3_new, Δ4_new, κ_new
    end
    
    return k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ
end

# Bootstrap EM for parameter estimation and standard errors
function bootstrap_em(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data, num_bootstraps::Int, max_iters)
    n = length(unique(data.pid))  # Number of observations
    num_params = 28    # Number of parameters
    bootstrapped_params = zeros(num_params, num_bootstraps)

    for b in 1:num_bootstraps
        # Generate bootstrap sample
        bootstrap_indices = rand(1:n, n)  # Sample with replacement
        bootstrap_data = data[bootstrap_indices, :]

        # EM algorithm on bootstrap sample
        k1_b = copy(k1)
        k2_b = copy(k2)
        k3_b = copy(k3)
        k4_b = copy(k4)
        Δ1_b = copy(Δ1)
        Δ2_b = copy(Δ2)
        Δ3_b = copy(Δ3)
        Δ4_b = copy(Δ4)
        κ_b = copy(κ)

        for iter in 1:max_iters
            # Draw latent factors
            θ = draw_samples_positive(k1_b, Δ1_b, k2_b, Δ2_b, k3_b, Δ3_b, k4_b, Δ4_b, κ_b, R, bootstrap_data) ## Adjust as per your draw_samples function

            # E-step
            println("Starting E-step iteration $iter")
            posterior = expectation_step_n(k1_b, Δ1_b, k2_b, Δ2_b, k3_b, Δ3_b, k4_b, Δ4_b, κ, θ, R, bootstrap_data)
            println("Completed E-step iteration $iter")

            # M-step
            println("Starting M-step iteration $iter")
            k1_new, k2_new, k3_new, k4_new, Δ1_new, Δ2_new, Δ3_new, Δ4_new, κ_new = m_step(posterior, θ, R, bootstrap_data)
            println("Completed M-step iteration $iter")

            # Check convergence
            κ_change = norm(κ_new - κ_b) / max(norm(κ_b), 1e-6)
            k1_change = norm(k1_new - k1_b) / max(norm(k1_b), 1e-6)
            k2_change = norm(k2_new - k2_b) / max(norm(k2_b), 1e-6)
            k3_change = norm(k3_new - k3_b) / max(norm(k3_b), 1e-6)
            k4_change = norm(k4_new - k4_b) / max(norm(k4_b), 1e-6)
            Δ1_change = norm(Δ1_new - Δ1_b) / max(norm(Δ1_b), 1e-6)
            Δ2_change = norm(Δ2_new - Δ2_b) / max(norm(Δ2_b), 1e-6)
            Δ3_change = norm(Δ3_new - Δ3_b) / max(norm(Δ3_b), 1e-6)
            Δ4_change = norm(Δ4_new - Δ4_b) / max(norm(Δ4_b), 1e-6)

            # Check if all changes are below the convergence threshold
            if κ_change < 0.001 && k1_change < 0.001 && k2_change < 0.001 && k3_change < 0.001 && k4_change < 0.001 && Δ1_change < 0.001 && Δ2_change < 0.001 && Δ3_change < 0.001 && Δ4_change < 0.001
                println("Converged after $iter iterations.")
                break
            end

            k1_b, k2_b, k3_b, k4_b, Δ1_b, Δ2_b, Δ3_b, Δ4_b, κ_b = k1_new, k2_new, k3_new, k4_new, Δ1_new, Δ2_new, Δ3_new, Δ4_new, κ_new
        end

        # Store the estimated parameters for the bootstrap sample
        Ψ_bootstrap = [k1_b; k2_b; k3_b; k4_b; vec(Δ1_b); vec(Δ2_b); vec(Δ3_b); vec(Δ4_b); κ_b]
        bootstrapped_params[:, b] = Ψ_bootstrap
    end

    return bootstrapped_params
end

# Compute Bootstrapped Standard Errors and Final Parameters
function compute_final_estimates_and_standard_errors(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data, num_bootstraps::Int, max_iters)
    num_params = 28    # Number of parameters
    # Estimate parameters on the original data
    k1_fin, Δ1_fin, k2_fin, Δ2_fin, k3_fin, Δ3_fin, k4_fin, Δ4_fin, κ_fin = em_algorithm(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data; max_iters)
    
    # Compute bootstrapped parameters
    bootstrapped_params = bootstrap_em(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data, num_bootstraps, max_iters)

    # Compute standard errors
    std_errors = std(bootstrapped_params, dims=2)

    # Compute Confidence Intervals
    alpha = 0.1  # 90% confidence interval
    lower_percentile = 100 * alpha / 2
    upper_percentile = 100 * (1 - alpha / 2)
    confidence_intervals = zeros(num_params, 2)

    for i in 1:num_params
        sorted_params = sort(bootstrapped_params[i, :])
        confidence_intervals[i, 1] = sorted_params[round(Int, lower_percentile * num_bootstraps / 100)]
        confidence_intervals[i, 2] = sorted_params[round(Int, upper_percentile * num_bootstraps / 100)]
    end    

    # Combine final estimates and standard errors in a dictionary for easy access
    final_estimates = [k1_fin; k2_fin; k3_fin; k4_fin; vec(Δ1_fin); vec(Δ2_fin); vec(Δ3_fin); vec(Δ4_fin); κ_fin]
    results = Dict(
        "Final Estimates" => final_estimates,
        "Standard Errors" => std_errors,
        "Confidence Intervals" => confidence_intervals
    )

    return results
end

# Compute the Signal to Noise Ratio
function noise(α, σ, θ)
    J = 7 # The number of measures

    s = zeros(J)
    
    for j in 1:J
        if j in 1:3 # cognitions
            s[j] = α[j]^2 * var(θ[:, :, 1]) / (α[j]^2 * var(θ[:, :, 1]) + σ[j]^2)
        elseif j in 4:7 # gender role
            s[j] = α[j]^2 * var(θ[:, :, 2]) / (α[j]^2 * var(θ[:, :, 2]) + σ[j]^2)
        end
    end

    return s
end
