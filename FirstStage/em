            #Δ2_num += posterior[i, r, 2] .* ((θ[i, r, :] - k2_new) * transpose(θ[i, r, :] - k2_new))
            Δ2_num += posterior[i, r, 2] .* (θ[i, r, :] * transpose(θ[i, r, :]))
        end
    end

    if κ_num2 != 0
        #Δ2_new = Δ2_num ./ κ_num2
        Δ2_new = Δ2_num ./ κ_num2 - (k2_new * transpose(k2_new))
    end

    if is_not_positive_definite(Δ2_new)
        ensure_positive_definite!(Δ2_new)
    end

    # (4) k3, Δ3
    for i in 1:n
        for r in 1:R
            k3_num += posterior[i, r, 3] .* θ[i, r, :]
        end
    end

    if κ_num3 != 0
        k3_new = k3_num ./ κ_num3
    end

    for i in 1:n
        for r in 1:R
            #Δ3_num += posterior[i, r, 3] .* ((θ[i, r, :] - k3_new) * transpose(θ[i, r, :] - k3_new))
            Δ3_num += posterior[i, r, 3] .* (θ[i, r, :] * transpose(θ[i, r, :]))
        end
    end

    if κ_num3 != 0
        #Δ3_new = Δ3_num ./ κ_num3
        Δ3_new = Δ3_num ./ κ_num3 - (k3_new * transpose(k3_new))
    end

    if is_not_positive_definite(Δ3_new)
        ensure_positive_definite!(Δ3_new)
