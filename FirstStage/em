function update(θ, μ, α, σ, data::DataFrame)
    n = length(unique(data.pid))
    
    # Update α, μ, and σ in a single loop
    
    # (1) Censored
    for j in 10:21
        if 10 ≤ j ≤ 13
            θ_index = 4
        elseif 14 ≤ j ≤ 17
            θ_index = 5
        elseif 18 ≤ j ≤ 21
            θ_index = 6
        end
        
        # Sample moments
        mean_y = mean(data[:, Symbol("meas", j)])
        mean_θ = mean(θ[:, θ_index])
        cov = 0.0
        var_θ = 0.0
        var_y = 0.0
        for i in 1:n
            cov += (data[i, Symbol("meas", j)] - mean_y) * (θ[i, θ_index] - mean_θ)
            var_θ += (θ[i, θ_index] - mean_θ)^2
            var_y += (data[i, Symbol("meas", j)] - mean_y)^2
        end
        α[j] = cov / var_θ
        μ[j] = mean_y - α[j] * mean_θ
        σ[j] = sqrt(var_y - cov * α[j])
        
    end

    # (2) Continuous Measures
    for j in 1:9
        if 1 ≤ j ≤ 3
            θ_index = 1
        elseif 4 ≤ j ≤ 6
            θ_index = 2
        elseif 7 ≤ j ≤ 9
            θ_index = 3
        end

        s_xx = 0.0
        s_xy = 0.0
        mean_y = 0.0
        mean_θ = 0.0
        for i in 1:n
            mean_y += data[i, Symbol("meas", j)] / n
            mean_θ += θ[i, θ_index] / n
            s_xx += (θ[i, θ_index] - mean_θ)^2 / n
            s_xy += (data[i, Symbol("meas", j)] - mean_y) * (θ[i, θ_index] - mean_θ) / n
        end

        α[j] = s_xy / s_xx
        μ[j] = mean_y - α[j] * mean_θ

        u = 0.0
        for i in 1:n
            u += (data[i, Symbol("meas", j)] - μ[j] - α[j] * θ[i, θ_index])^2 / n
        end
        σ[j] = sqrt(u)
        
        #α[j] = R * (sum(data[:, Symbol("meas", j)]) * sum(θ[:, :, θ_index]) - 
        #            n * sum(sum(data[i, Symbol("meas", j)] * θ[i, r, θ_index] for r in 1:R) for i in 1:n)) / 
        #            (sum(θ[:, :, θ_index])^2 - n * R * sum(sum(θ[i, r, θ_index]^2 for r in 1:R) for i in 1:n))
        
        #μ[j] = (R * sum(data[:, Symbol("meas", j)]) - α[j] * sum(θ[:, :, θ_index])) / (n * R)
        
        #σ[j] = sqrt(var(data[:, Symbol("meas", j)]) - α[j]^2 * var(θ[:, :, θ_index]))
    end

    # Set specific indices of α and μ
    α[[1, 4, 7, 10, 14, 18]] .= 1.0
    μ[[1, 4, 7, 10, 14, 18]] .= 0.0

    return μ, α, σ
end

# EM algorithm
function em_algorithm(k1, Δ1, k2, Δ2, κ, μ, α, σ, R, data::DataFrame; max_iters)
    
    for iter in 1:max_iters
        # Draw latent factors
        θ = draw_samples_positive_fast(k1, Δ1, k2, Δ2, κ, R, data) ## n by R by 2 array
        
        # E-step
        println("Starting E-step iteration $iter")
        posterior = expectation_step_n(k1, Δ1, k2, Δ2, κ, θ, R, data)
        println("Completed E-step iteration $iter")
        
        # M-step
        println("Starting M-step iteration $iter")
        k1_new, k2_new, Δ1_new, Δ2_new, κ_new = m_step(posterior, θ, R, data)
        println("Completed M-step iteration $iter")
        
        # Check convergence
        κ_change = norm(κ_new - κ) / max(norm(κ), 1e-6)
        k1_change = norm(k1_new - k1) / max(norm(k1), 1e-6)
        k2_change = norm(k2_new - k2) / max(norm(k2), 1e-6)
        #k3_change = norm(k3_new - k3) / max(norm(k3), 1e-6)
        #k4_change = norm(k4_new - k4) / max(norm(k4), 1e-6)
        Δ1_change = norm(Δ1_new - Δ1) / max(norm(Δ1), 1e-6)
        Δ2_change = norm(Δ2_new - Δ2) / max(norm(Δ2), 1e-6)
        #Δ3_change = norm(Δ3_new - Δ3) / max(norm(Δ3), 1e-6)
        #Δ4_change = norm(Δ4_new - Δ4) / max(norm(Δ4), 1e-6)
        
        # Check if all changes are below the convergence threshold
        if κ_change < 1e-6 && k1_change < 1e-6 && k2_change < 1e-6 Δ1_change < 1e-6 && Δ2_change < 1e-6 #&&
            #k3_change < 0.001 && k4_change < 0.001 && Δ3_change < 0.001 && Δ4_change < 0.001
            println("Converged after $iter iterations.")
            break
        end
    
        #k1, k2, k3, k4, Δ1, Δ2, Δ3, Δ4, κ = k1_new, k2_new, k3_new, k4_new, Δ1_new, Δ2_new, Δ3_new, Δ4_new, κ_new
        k1, k2, Δ1, Δ2, κ = k1_new, k2_new, Δ1_new, Δ2_new, κ_new

        θ = draw_samples_positive_one(k1, Δ1, k2, Δ2, κ, data)

        # Update Measurement Parameters
        μ, α, σ = update(θ, μ, α, σ, data)
    end

    #return k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ
    return k1, Δ1, k2, Δ2, κ, μ, α, σ
end

