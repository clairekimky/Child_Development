            println("Completed E-step iteration $iter")

            # M-step
            println("Starting M-step iteration $iter")
            k1_new, k2_new, Δ1_new, Δ2_new, κ_new = m_step(posterior, θ, R, bootstrap_data)
            println("Completed M-step iteration $iter")

            # Check convergence
            κ_change = norm(κ_new - κ_b) / max(norm(κ_b), 1e-6)
            k1_change = norm(k1_new - k1_b) / max(norm(k1_b), 1e-6)
