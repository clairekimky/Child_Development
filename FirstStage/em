function generate_invertible_matrix()
    A = rand(2, 2)  # Generate a 2x2 matrix with random elements between 0 and 1
    while det(A) ≈ 0.0  # Check if the determinant is approximately zero
        A = rand(2, 2)  # If the matrix is singular, generate a new random matrix
    end
    return A
end

function is_not_positive_definite(Δ::AbstractMatrix)
    try
        cholesky(Δ)
        return false
    catch
        return true
    end
end

function ensure_positive_definite!(Δ::AbstractMatrix; tol::Float64=1e-6)
    max_iters = 100
    perturbation = 1e-3
    iter = 0
    
    while is_not_positive_definite(Δ) && iter < max_iters
        Δ .+= perturbation * Diagonal(I, size(Δ, 1))
        
        # Adjust diagonal elements if necessary
        for k in 1:size(Δ, 1)
            if Δ[k, k] <= 0
                Δ[k, k] = abs(Δ[k, k]) + tol
            end
        end
        
        # Check positive definiteness based on eigenvalues
        if is_not_positive_definite(Δ)
            min_eigenvalue = minimum(eigen(Δ).values)
            Δ .+= max(abs(min_eigenvalue), tol) * Diagonal(I, size(Δ, 1))
        end
        
        perturbation *= 2  # Increase perturbation for next iteration
        iter += 1
    end
    
    if iter == max_iters
        error("Unable to make the matrix positive definite after $max_iters iterations.")
    end
end

function draw_samples_positive(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, R, data::DataFrame)
    println("Inside factor draw")
    n = length(unique(data.pid))  # Number of individuals
    K = 2 # Number of latent factors
    θ_samples = zeros(Float64, n, R, K)  # a 2-dimensional array (or matrix) of size (n X R X K) filled with zeros
    
    # Cholesky decompositions of the covariance matrices
    L1 = cholesky(Δ1).L
    L2 = cholesky(Δ2).L
    L3 = cholesky(Δ3).L
    L4 = cholesky(Δ4).L

    for i in 1:n
        for r in 1:R

            # Draw a random sample from a Bernoulli distribution with probability κ
            u = rand()
            if u < κ[1]
                z = randn(length(k1))
                θ_samples[i, r, :] = k1 + L1*z
            elseif u < κ[1] + κ[2]
                z = randn(length(k2))
                θ_samples[i, r, :] = k2 + L2*z
            elseif u < κ[1] + κ[2] + κ[3]
                z = randn(length(k3))
                θ_samples[i, r, :] = k3 + L3*z
            else
                z = randn(length(k4))
                θ_samples[i, r, :] = k4 + L4*z
            end         
        end
    end

    return θ_samples # n X R X K Array
end

# Function to compute the likelihood of observed z given theta for continuous measures
function likelihood_cont(μ, α, σ, θ, R, data::DataFrame)
    println("Inside likelihood_cont")
    #println("Inside likelihood_cont")
    n = length(unique(data.pid))  # Number of individuals
    J = 3  # Number of continuous measurements

    #Initialize likelihood
    likelihoods = zeros(Float64, n, R) # n X R Matrix

    # Precompute the valid indices
    #valid_indices = [data[i, Symbol("meas", j)] != -999 for i in 1:n, j in 1:J]

    for i in 1:n
        for r in 1:R
            p_cont_product = 1.0
            for j in 1:J
                #if valid_indices[i, j]
                #μ[indices_to_zero_μ] .= 0
                #λ[indices_to_one_λ] .= 1
                prob = pdf(Normal(μ[j] + α[j] * θ[i, r, 1], abs(σ[j])), data[i, Symbol("meas", j)])         
                p_cont_product *= prob # \prod_{j = 1}^J Pr(z_{i, j} | θ_i) 
            end
            likelihoods[i, r] = p_cont_product
        end
    end
    return likelihoods # n X 2 matrix
end

# Function to compute the likelihood of observed z given theta for discrete measures
function likelihood_cens(μ, α, σ, θ, R, data::DataFrame)
    println("Inside likelihood_cens")
    #println("Inside likelihood_cens")
    n = length(unique(data.pid))  # Number of individuals
    J = 4  # Number of censored measurements

    #Initialize likelihood
    likelihoods = zeros(Float64, n, R)
    μ_j_theta = zeros(Float64, J)

    # Precompute the valid indices
    #valid_indices = [data[i, Symbol("meas", j + 3)] != -999 for i in 1:n, j in 1:J] # n X 32 Array

    for i in 1:n
        for r in 1:R
            p_cens_product = 1.0
            for j in 1:J
                #if valid_indices[i, j]                
                #μ[indices_to_zero_μ] .= 0
                #λ[indices_to_one_λ] .= 1
                μ_j_theta[j] = μ[j + 3] + (α[j + 3] * θ[i, r, 2])
                if data[i, Symbol("meas", j + 3)] == 1
                    p_cens = cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 2)
                elseif data[i, Symbol("meas", j + 3)] == 4
                    p_cens = 1.0 - cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 4)
                elseif data[i, Symbol("meas", j + 3)] == 2
                    p_cens = cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 3) - cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 2)
                elseif data[i, Symbol("meas", j + 3)] == 3
                    p_cens = cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 4) - cdf(Normal(μ_j_theta[j], abs(σ[j + 3])), 3)
                end
                p_cens_product *= p_cens
            end
            likelihoods[i, r] = p_cens_product
        end
    end
    return likelihoods # size(likelihoods) = n X 2
end

# Expectation step: Compute probabilities for each observation
function expectation_step_n(k1, Δ1, k2, Δ2, k3, Δ3, k4, Δ4, κ, θ, R, data::DataFrame)
    n = length(unique(data.pid))  # Number of observations

    posterior = zeros(Float64, n, R, 4)

    # Compute likelihoods for continuous and censored measurements
    cont = likelihood_cont(μ, α, σ, θ, R, data) # n X R array
    cens = likelihood_cens(μ, α, σ, θ, R, data)

    weight_num = zeros(n, R)
    weight_den = zeros(n)
    weight = zeros(n, R)

    for i in 1:n
        for r in 1:R
            weight_num[i, r] = cont[i, r] * cens[i, r]
            weight_den[i] += weight_num[i, r]
        end
    end

    for i in 1:n
        for r in 1:R
            if weight_den[i] != 0
                weight[i, r] = weight_num[i, r] / weight_den[i] # n X R Array
            end
        end
    end

    # Compute posterior probabilities
    for i in 1:n
        for r in 1:R
            num1 = κ[1] * pdf(MvNormal(k1, Δ1), θ[i, r, :])
            num2 = κ[2] * pdf(MvNormal(k2, Δ2), θ[i, r, :])
            num3 = κ[3] * pdf(MvNormal(k3, Δ3), θ[i, r, :])
            num4 = κ[4] * pdf(MvNormal(k4, Δ4), θ[i, r, :])
            den = num1 + num2 + num3 + num4

            if den != 0
                posterior[i, r, 1] = weight[i, r] * (num1 / den)
                posterior[i, r, 2] = weight[i, r] * (num2 / den)
                posterior[i, r, 3] = weight[i, r] * (num3 / den)
                posterior[i, r, 4] = weight[i, r] * (num4 / den)
            end
        end
    end

    return posterior # n X R X 2 Array
end

# M-step: Update the parameters
function m_step(posterior, θ, R, data::DataFrame)
    n = length(unique(data.pid))
    K = 2 # the number of elements in θ

    # Initialize
    κ_num1 = 0.0
    κ_num2 = 0.0
    κ_num3 = 0.0
    κ_num4 = 0.0
    κ_new = zeros(Float64, 4)
    k1_num = zeros(Float64, K)
    k1_new = zeros(Float64, K)
    Δ1_num = zeros(Float64, K, K)
    Δ1_new = zeros(Float64, K, K)
    k2_num = zeros(Float64, K)
    k2_new = zeros(Float64, K)
    Δ2_num = zeros(Float64, K, K)
    Δ2_new = zeros(Float64, K, K)
    k3_num = zeros(Float64, K)
    k3_new = zeros(Float64, K)
    Δ3_num = zeros(Float64, K, K)
    Δ3_new = zeros(Float64, K, K)
    k4_num = zeros(Float64, K)
    k4_new = zeros(Float64, K)
    Δ4_num = zeros(Float64, K, K)
    Δ4_new = zeros(Float64, K, K)
    
    # Update parameters
    # (1) κ
    for i in 1:n
        for r in 1:R
            κ_num1 += posterior[i, r, 1]
            κ_num2 += posterior[i, r, 2]
            κ_num3 += posterior[i, r, 3]
            κ_num4 += posterior[i, r, 4]
        end
    end

    κ_new[1] = κ_num1 / n
    κ_new[2] = κ_num2 / n
    κ_new[3] = κ_num3 / n
    κ_new[4] = κ_num4 / n

    # Normalize κ to ensure elements are between 0 and 1 and their sum equals 1
    κ_sum = sum(κ_new)
    if κ_sum != 0
        κ_new .= κ_new ./ κ_sum
    end

    # (2) k1, Δ1
    for i in 1:n
        for r in 1:R
            k1_num += posterior[i, r, 1] .* θ[i, r, :]
        end
    end

    if κ_num1 != 0
        k1_new = k1_num ./ κ_num1
    end

    for i in 1:n
        for r in 1:R
            #Δ1_num += posterior[i, r, 1] .* ((θ[i, r, :] - k1_new) * transpose(θ[i, r, :] - k1_new))
            Δ1_num += posterior[i, r, 1] .* (θ[i, r, :] * transpose(θ[i, r, :]))
        end
    end

    if κ_num1 != 0
        #Δ1_new = Δ1_num ./ κ_num1
        Δ1_new = Δ1_num ./ κ_num1 - (k1_new * transpose(k1_new))
    end

    if is_not_positive_definite(Δ1_new)
        ensure_positive_definite!(Δ1_new)
    end

    # (3) k2, Δ2
    for i in 1:n
        for r in 1:R
