***********************
* Summary Satatistics *
***********************

* Demographics
gen female = sex==2 // Create a female indicator
gen black = race==2 // Black indicator
gen hisp = race==1 // hispanic indicator
gen numsib = numkid - 1 // number of siblings
replace urban = . if urban == 2

gen compparent = 1 if comlearn == 3
replace compparent = 0 if inrange(comlearn, 1, 2) | inrange(comlearn, 4, 6) | comlearn == 0

* Mom Characteristics
gen myear1stbirth = year - mage + mfirstbirth
gen firstchild = 1 if myear1stbirth == byear
replace firstchild = 0 if myear1stbirth < byear // Create first child indicator

gen famincome = mincome + fincome if mincome > 0 & fincome > 0 & mincome ~=. & fincome ~=.
replace famincome = mincome if famincome == . & mincome > 0 & mincome ~=. & fincome == 0
replace famincome = fincome if famincome == . & fincome > 0 & fincome ~=. & mincome == 0 // create family income

replace medu =. if medu == 95

*CPI-adjusted income using 1983 as the index (1983 = 100)
gen cpi = 148.2 if year == 1994
replace cpi = 156.9 if year == 1996
replace cpi = 163.0 if year == 1998
replace cpi = 172.2 if year == 2000
replace cpi = 179.9 if year == 2002
replace cpi = 188.9 if year == 2004
replace cpi = 201.6 if year == 2006
replace cpi = 215.3 if year == 2008
replace cpi = 218.1 if year == 2010
replace cpi = 229.6 if year == 2012
replace cpi = 236.7 if year == 2014

gen inccpi = famincome * 100 / cpi

save "/Users/clairekim/Desktop/Project/Child Development/STATA/empirics.dta", replace

* Descriptive Statistics

use empirics, clear

* Baseline
sum female black urban numsib firstchild medu mage inccpi if !missing(medu, inccpi, firstchild, urban)
