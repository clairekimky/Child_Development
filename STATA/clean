corr concent1 concent2 concent3 concent4 concent5

*(6) Childs' Age
drop age
gen age = 0 if wave == 3 & cohort_n == 2
replace age = 1 if wave == 4 & cohort_n == 2
replace age = 2 if wave == 5 & cohort_n == 2
replace age = 3 if wave == 6 & cohort_n == 2
replace age = 1 if wave == 6 & cohort_n == 1
