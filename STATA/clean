************* Generate weekly time use

*(1) Weekdays
gen si_weekday = simean*5 if inrange(day, 1, 5)
*gen sleep_weekday = sleepmean * 5 if inrange(day, 1, 5)
gen tutor_weekday = tutmean*5 if inrange(day, 1, 5)
