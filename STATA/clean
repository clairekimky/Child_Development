************ Replacing values

*(1) Child's grade
gen grade_n = 3 if grade == 19
replace grade_n = 4 if grade == 20
replace grade_n = 5 if grade == 23
replace grade_n = 6 if grade == 24
replace grade_n = 7 if grade == 25
replace grade_n = 8 if grade == 26
replace grade_n = 9 if grade == 27
replace grade_n = 10 if grade == 28
replace grade_n = 11 if grade == 29

