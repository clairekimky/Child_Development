rename grade_n grade

*(2) Homework indicator
replace hwind = 0 if hwind == 2 

*(3) Pocket Money (weekly)
replace pmind = 0 if pmind == 2

*(4) Extra pocket money
replace epmind = 0 if epmind == 2

*(5) Weekly Pocket money amount
* Cohort K in Wave 4 not included
replace pmamount = pmyear * (1/52) if pmamount == . & pmyear ~= .
replace pmamount = pmtot if pmperiod == 1 & pmamount == .
