*********** Destringing

destring pcodes, replace
encode cohort, gen(cohort_n) // 1 Cohort B; 2 Cohort K
drop cohort

******** Missing observations

* Loop over each variable in the dataset
foreach var of varlist _all {
    * Replace negative values with missing values
    replace `var' = . if `var' < 0
}

* Loop over NAPLAN variable in the dataset
foreach var of varlist num read write {
    * Replace negative values with missing values
    replace `var' = . if `var' == 0
}

********** Combine day & dow

replace day = dow if wave == 4
drop dow

******** Match Parent ID with Mother and Father ID using sex indicator

* Value is 3 if biological child
 
gen mbio = p2bio if p1sex == 1 // p1sex = 1 if Male and = 2 if Female
replace mbio = p1bio if p1sex == 2
replace mbio = -9 if p1sex==-9
replace mbio = p1bio if p1sex== p2sex

gen fbio = p1bio if p1sex==1
replace fbio = p2bio if p1sex==2
replace fbio = -9 if p1sex==-9
replace fbio = p2bio if p1sex== p2sex

******** Generate variables

*(1) Child's Female Indicator
gen female = .
replace female = 1 if sex == 2 // Female indicator
replace female = 0 if sex == 1 // Female indicator
drop sex

*(2) Parent's education

** 1 Year 12 or equivalent; 2 Year 11 or equivalent; 3 Year 10 or equivalent; 4 Year 9 or equivalent; 5 Year 8 or below; 6 Never attended school

gen mhs = p2hs if p1sex == 1 // p1sex = 1 if Male and = 2 if Female
replace mhs = p1hs if p1sex == 2
replace mhs = -9 if p1sex==-9
replace mhs = p1hs if p1sex== p2sex

gen fhs = p1hs if p1sex==1
replace fhs = p2hs if p1sex==2
replace fhs = -9 if p1sex==-9
replace fhs = p2hs if p1sex== p2sex

** 1 Postgraduate degree; 2 Graduate diploma/certificate; 3 Bachelor degree; 4 Advanced diploma/diploma; 5 Certificate; 6 Other

gen medu = p2edu if p1sex == 1
replace medu = p1edu if p1sex == 2
replace medu = -9 if p1sex==-9
replace medu = p1edu if p1sex== p2sex

gen fedu = p1edu if p1sex==1
replace fedu = p2edu if p1sex==2
replace fedu = -9 if p1sex==-9
replace fedu = p2edu if p1sex== p2sex

gen medu1 = medu if wave == 4 & cohort_n == 2
replace medu1 = medu if wave == 6 & cohort_n == 1

order cid wave medu1

sort cid wave
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 5 & medu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 6 & medu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 7 & medu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 7 & medu1[_n-1] ~= . & cohort_n == 1
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 8 & medu1[_n-1] ~= . & cohort_n == 1
bysort cid (wave): replace medu1 = medu1[_n-1] if wave == 9 & medu1[_n-1] ~= . & cohort_n == 1

gen fedu1 = fedu if wave == 4 & cohort_n == 2
replace fedu1 = fedu if wave == 6 & cohort_n == 1

order cid wave fedu1

bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 5 & fedu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 6 & fedu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 7 & fedu1[_n-1] ~= . & cohort_n == 2
bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 7 & fedu1[_n-1] ~= . & cohort_n == 1
bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 8 & fedu1[_n-1] ~= . & cohort_n == 1
bysort cid (wave): replace fedu1 = fedu1[_n-1] if wave == 9 & fedu1[_n-1] ~= . & cohort_n == 1

drop p1hs p2hs p1edu p2edu

*(3) Parent's Labor Force Status

** 1 Employed; 2 Unemployed; 3 Not in Labor Force

gen memp = p2emp if p1sex == 1
replace memp = p1emp if p1sex == 2
replace memp = -9 if p1sex==-9
replace memp = p1emp if p1sex== p2sex

gen femp = p1emp if p1sex==1
replace femp = p2emp if p1sex==2
replace femp = -9 if p1sex==-9
replace femp = p2emp if p1sex== p2sex

** 1 Full time; 2 Part-time or unknown hours; 3 Maternity leave; 4 Unemployed; 5 Not in Labor force

gen mwork = p2work if p1sex == 1
replace mwork = p1work if p1sex == 2
replace mwork = -9 if p1sex==-9
replace mwork = p1work if p1sex== p2sex

gen fwork = p1work if p1sex==1
replace fwork = p2work if p1sex==2
replace fwork = -9 if p1sex==-9
replace fwork = p2work if p1sex== p2sex

gen mfull = 1 if mwork == 1
replace mfull = 0 if inrange(mwork, 2, 5)
gen ffull = 1 if fwork == 1
replace ffull = 0 if inrange(fwork, 2, 5)

drop p1emp p2emp p1work p2work

** Labor Market Income (Weekly)

gen mominc = p2inc if p1sex == 1
replace mominc = p1inc if p1sex == 2
replace mominc = -9 if p1sex==-9
replace mominc = p1inc if p1sex== p2sex

gen dadinc = p1inc if p1sex==1
replace dadinc = p2inc if p1sex==2
replace dadinc = -9 if p1sex==-9
replace dadinc = p2inc if p1sex== p2sex

replace mominc = . if mominc == 0 & memp == 1 // 
replace dadinc = . if dadinc == 0 & femp == 1 //

