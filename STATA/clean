*gen sleep_weekend = sleepmean*2 if inrange(day, 6, 7)
gen tutor_weekend = tutmean*2 if inrange(day, 6, 7)
gen siweekend = simean if inrange(day, 6, 7)

********** Generate total household income

gen hhinc = mominc + dadinc if mominc ~= . & dadinc ~=.

*CPI-adjusted income using 2010 as the index (2010 = 100)
gen cpi = 100 if wave == 4
replace cpi = 105.12 if wave == 5
replace cpi = 110.37 if wave == 6
replace cpi = 113.48 if wave == 7
replace cpi = 117.89 if wave == 8

gen hhinccpi = hhinc * 100 / cpi if hhinc ~= .

sort cid age

************** Generate deflated pockey money amount

*replace pmamount =. if pmamount > 50
gen pmcpi = pmamount * 100 / cpi if pmamount ~= .

sort cid age

************** Generate birth order

gen border = .
replace border = 1 if cage == oldage & cage ~= . & oldage ~= .
replace border = 0 if cage < oldage & cage ~= . & oldage ~= .

********************* Generate Parent's Age

gen mage = p2age if p1sex == 1
replace mage = p1age if p1sex == 2
replace mage = -9 if p1sex==-9
replace mage = p1age if p1sex== p2sex

gen fage = p1age if p1sex==1
replace fage = p2age if p1sex==2
replace fage = -9 if p1sex==-9
replace fage = p2age if p1sex== p2sex

