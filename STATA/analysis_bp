
clear all
set more off

*============================*
* Project: Child Development *
* File: analysis_bp.do          *
*============================*

global root "/Users/clairekim/Desktop/Project/Child Development/LSAC"
global data "$root/analysis"
global figs "$root/analysis/figs"

cd "$data"

capture mkdir "$root/logs"
log using "$root/logs/analysis.log", replace text

*====================================*
* 1. Load and Prepare Data
*====================================*

use analysis, clear
sort cid age
rename cohort_n cohort
xtset cid age

****** Sample Restriction ******

/*
All of my results are based on a selected sample of LSAC households that meet several criteria.
First, only stable, two-parent households are included.
Second, all children are biological (i.e., no adopted children or step-parents).
Third, each selected child has an observed NAPLAN score at age 10-11.
Finally, I retain only observations for children aged 10 to 15.
*/

* Count sample size
bysort cid: gen noid = [_n]

replace fage = . if fage == 1 // Treat 1 year old father as missing

*====================================*
* 2. Variable Construction
*====================================*

** Parents

gen mcol = .
replace mcol = 1 if inrange(medu1, 1, 3) // College moms
replace mcol = 0 if inrange(medu1, 4, 6) // Less than college moms

gen fcol = .
replace fcol = 1 if inrange(fedu1, 1, 3) // College dads
replace fcol = 0 if inrange(fedu1, 4, 6) // Less than college dads

****** Use uniform sample (comparable)

replace simean = . if simean > 10 & schoolmean != . & simean != .
replace simean = . if simean > 16 & simean != . & schoolmean == . // Exclude outliers from the sample analysis
replace siweekday = . if siweekday > 10 & schoolmean != . & siweekday != .
replace siweekend = . if siweekend > 16 & siweekend != . & schoolmean == . // Exclude outliers from the sample analysis

***** Complete CPM
gen cpm_n = .
replace cpm_n = cpm
replace cpm_n = 1 if ecpm == 1 // CPM + ECPM

gen weekday = 1 if inrange(day, 1, 5)
replace weekday = 0 if inrange(day, 6, 7)

gen cpm_all = cpm_n if cpm_n !=.
replace cpm_all = 0 if pmind == 0

replace pmamount = 0 if pmind == 0 & pmamount == . // Not receiving pocket money = Not receiving CPM

**** Create Parents' Employment Variable

gen jointwork = .
replace jointwork = 0 if dadwork == 1 & inrange(momwork, 3, 5) // Dad is full-time working but mom is not working (e.g., maternity leave, unemployed, not in LF)
replace jointwork = 1 if dadwork == 1 & momwork == 2 // Dad is full-time working but mom is part-time working
replace jointwork = 2 if dadwork == 1 & momwork == 1 // Both dad and mom are full-time working

*====================================*
* 3. Panel Construction and Cleaning
*====================================*

gen sampleok = ///
    inrange(age, 1, 3) & /// age 10–15
    bio == 1 & /// biological child
    cob == 1101 /// Australian-born

tab noid if sampleok
tab cohort if sampleok & noid == 1

keep if sampleok
keep cid age cage grade mage fage mcol fcol jointwork momwrkhr dadwrkhr dadwork momwork mominc dadinc simean pmind weekday read num write pmamount cpm_all numsib female border schoolmean day pmcpi siweekday siweekend hypscore cohort wave

xtset cid age
xtdescribe

bysort cid: gen n_obs = _N
sum age
local total_periods = r(max) - r(min) + 1

drop if n_obs < `total_periods'

drop n_obs 

tab cohort

*====================================*
* 4. Measurement Adjustments
*====================================*

sum schoolmean if inrange(day, 1, 5) & schoolmean != . & age == 1, detail
sum schoolmean if inrange(day, 1, 5) & schoolmean != . & age == 2, detail
sum schoolmean if inrange(day, 1, 5) & schoolmean != . & age == 3, detail

gen schhr = .
replace schhr = 6.666667 if age == 1 & weekday == 1 & schoolmean != .
replace schhr = 6.783333 if age == 2 & weekday == 1 & schoolmean != .
replace schhr = 6.75     if age == 3 & weekday == 1 & schoolmean != .
replace schhr = 0 if weekday == 0 & inrange(age,1,3)

sort cid age

keep if schhr != .
keep if dadinc > 0 & dadinc != .
keep if hypscore != .
keep if mage != .
keep if mcol != .

replace schhr = 60*schhr

*** Dealing with reporting errors in the parental income and labor supply data

replace momwrkhr = 80 if momwrkhr > 80
replace dadwrkhr = 80 if dadwrkhr > 80 // if the labor supply for a given spouse was above 80 hours per week, truncate that observation at 80

gen miss = .
replace miss = 1 if mominc > 0 & momwrkhr == 0 // the reported labor income is positive but the reported labor hours are 0
replace miss = 1 if mominc == 0 & momwrkhr > 0 // the reported labor hours are positive but the labor income is 0
replace miss = 1 if mominc == . & momwrkhr == . // either reported labor hours or labor income is missing

gen mwage = mominc / momwrkhr if miss != 1
gen fwage = dadinc / dadwrkhr if miss != 1

gen trunc = .
replace trunc = 1 if mwage < 7 | mwage > 210
replace trunc = 1 if fwage < 7 | fwage > 210 // If an hourly wage rate for a given spouse was either less than 7 AUD per hour or more than 210 AUD per hour, replace that observation by a missing value

*** CPI-adjusted income using 2010 as the index (2010 = 100)

gen cpi = .
replace cpi = 100 if wave == 4
replace cpi = 105.12 if wave == 5
replace cpi = 110.37 if wave == 6
replace cpi = 113.48 if wave == 7
replace cpi = 117.89 if wave == 8

gen fwagecpi = fwage * 100 / cpi if fwage != .
gen mwagecpi = mwage * 100 / cpi if mwage != .

drop cpi

*====================================*
* 5. Final Sample and Dataset
*====================================*

xtset cid age
xtdescribe

* Step 1: Count the number of distinct age values per cid
bysort cid: egen num_periods = total(inlist(age, 1, 2, 3))

* Step 2: Keep only those cids that have observations for all 3 periods (t = 1, 2, and 3)
keep if num_periods == 3

* Step 3: Drop the helper variable
drop num_periods

keep if age != .

sort cid age 

save "data_bp.dta", replace

use data_bp, clear

bysort cid: gen noid = [_n]
tab noid
drop noid

tab cohort

*====================================*
* 6. Descriptive Analysis
*====================================*

replace pmcpi = 0 if pmamount == 0

sum pmind pmcpi mage fage momwrkhr dadwrkhr mwagecpi fwagecpi cpm_all simean siweekday siweekend schoolmean read hypscore if miss != 1 & trunc != 1 // Make simple tables of descriptive statistics. Put `i' in front of factor variables

sum pmcpi if pmind == 1 & miss != 1 & trunc != 1 

tab dadwork if miss != 1 & trunc != 1
tab momwork if miss != 1 & trunc != 1 

***** Main Variables disaggregated by child's age

dtable pmind pmcpi cpm_all simean siweekday siweekend schoolmean momwrkhr dadwrkhr mwagecpi fwagecpi if miss != 1 & trunc != 1, by(age) // Make simple tables of descriptive statistics. Put `i' in front of factor variables

dtable pmcpi if pmind == 1 & miss != 1 & trunc != 1, by(age)

*====================================*
* 7. Heterogeneity and Mechanisms
*====================================*

* Generate Initial SR variables
gen hyp_init = hypscore if age == 1
bysort cid (age): replace hyp_init = hyp_init[_n-1] if hyp_init[_n] == . & hyp_init[_n-1] != . & age > 1

sum hypscore, detail
sum hyp_init, detail

* Define low and high SR children
gen lowreg = 1 if inrange(hyp_init, 6, 10) // Low Self-Regulation (Bottom 25% of attention capacitiy)
replace lowreg = 0 if inrange(hyp_init, 0, 1) // High Self-Regulation (Top 25% of attention capacitiy)

*** Model and Counterfactuals Motivation 

* (1) Heterogeneity
foreach var of varlist fcol mcol read simean pmcpi {
    ttest `var' if miss != 1 & trunc != 1, by(lowreg)
}

* (2) CPM receivers no difference in study time but it matters for no CPM
foreach var of varlist simean {
    ttest `var' if cpm_all == 0 & miss != 1 & trunc != 1, by(lowreg)
}
foreach var of varlist simean {
    ttest `var' if cpm_all == 1 & miss != 1 & trunc != 1, by(lowreg)
}

* (3) Need higher money to induce low SR children to comply with CPM contract
foreach var of varlist pmcpi {
    ttest `var' if lowreg == 1 & miss != 1 & trunc != 1, by(cpm_all)
}
foreach var of varlist pmcpi {
    ttest `var' if lowreg == 0 & miss != 1 & trunc != 1, by(cpm_all)
}

* (4) Parents' Labor Supply (Full-time vs Part-time)
* Group means
tabstat cpm_all pmcpi if miss != 1 & trunc != 1, by(jointwork) stats(mean sd n)

* FT vs PT
ttest cpm_all if (jointwork==1 | jointwork==2) & miss!=1 & trunc!=1, by(jointwork)
ttest pmcpi if (jointwork==1 | jointwork==2) & miss!=1 & trunc!=1, by(jointwork)

*====================================*
* 8. Figures
*====================================*

********* Trend in test scores (All Sample)

egen avgread = mean(read) if miss!=1 & trunc!=1, by(age)
	
line avgread age, sort ///
    ytitle("NAPLAN Reading Scores", size(large)) ///
    xtitle("Child's Age", size(large)) ///
    graphregion(color(white)) ///
    plotregion(color(white)) ///
    lcolor(lavender) ///
	lwidth(thick) ///
    legend(pos(5) ring(0) col(1) size(large)) ///
    xlabel(1 "10–11" 2 "12–13" 3 "14–15", nogrid labsize(med)) ///
    ylabel(, nogrid labsize(large))
	
graph export "$figs/read_bp.png", replace as(png) name("Graph")

********* Trend in hyperactivity (All Sample)

egen avghyp = mean(hypscore) if miss!=1 & trunc!=1, by(age)

line avghyp age, sort ///
    ytitle("SDQ Hyperactivity Scale", size(large)) ///
	xtitle("Child's Age", size(large)) ///
    graphregion(color(white)) ///
	plotregion(color(white)) ///
	lcolor(lavender) ///
	lwidth(thick) ///
	legend(pos(5) ring(0) col(1) ///
    size(medsmall)) ///
    xlabel(1 "10–11" 2 "12–13" 3 "14–15", nogrid labsize(med)) ///
	ylabel(, nogrid labsize(large))

graph export "$figs/hyp_bp.png", replace as(png) name("Graph")

********* Trend in test scores (by Hyperactivity)

egen avgreadh = mean(read) if lowreg == 0 & miss!=1 & trunc!=1, by(age)
egen avgreadl = mean(read) if lowreg == 1 & miss!=1 & trunc!=1, by(age)

twoway connected avgreadh avgreadl age, sort ///
    ytitle("NAPLAN Reading Scores", size(large)) ///
    xtitle("Child's Age", size(large)) ///
    graphregion(color(white)) ///
    plotregion(color(white)) ///
    lcolor(midblue orange) ///
	lwidth(thick thick) ///
    lpattern(solid dash) ///
    msymbol(circle triangle) ///
    mcolor(midblue orange) ///
    msize(large large) ///
    legend(pos(5) ring(0) col(1) size(large) ///
        label(1 "High Self-Regulation") label(2 "Low Self-Regulation")) ///
    xlabel(1 "10-11" 2 "12-13" 3 "14-15", nogrid labsize(med)) ///
    ylabel(, nogrid labsize(large))
	
graph export "$figs/read_disp.png", replace as(png) name("Graph")

log close



