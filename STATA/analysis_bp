
clear all

cd "/Users/clairekim/Desktop/Project/Child Development/LSAC/analysis"

********** Third Stage: Analysis

use analysis, clear

sort cid age

rename cohort_n cohort

****** Sample Restriction ******

/*
All of my results are based on a selected sample of LSAC households that meet several criteria. First, only stable, two-parent households are included. Second, all children are biological (i.e., no adopted children or step-parents). Third, all selected children are at least 10 years old. Fourth, each selected child has an observed NAPLAN score. Finally, I retain only observations for children aged 10 to 15.
*/

* Count sample size
bysort cid: gen noid = [_n]

*drop if cid == 11104216 & noid == 2 // Double count
*drop if cid == 11104216 & noid == 4 // Double count

*drop if cid == 71111031 & nonact == 12.5 // Weird measure
replace fage = . if fage == 1 // Weird number

xtset cid age

****** Data Evidence *******

*(0) Basic Summary Statistics (Table 1)

** Parents

gen mcol = 1 if inrange(medu1, 1, 3)
replace mcol = 0 if inrange(medu1, 4, 6)
gen fcol = 1 if inrange(fedu1, 1, 3)
replace fcol = 0 if inrange(fedu1, 4, 6)

****** Use uniform sample (comparable)

replace simean = . if simean > 10 & schoolmean ~= . & simean ~= .
replace simean = . if simean > 16 & simean ~= . & schoolmean == . // Exclude outliers from the sample analysis

***** Complete CPM
gen cpm_n = .
replace cpm_n = cpm
replace cpm_n = 1 if ecpm == 1 // CPM + ECPM

gen weekday = 1 if inrange(day, 1, 5)
replace weekday = 0 if inrange(day, 6, 7)

gen cpm_all = cpm_n if cpm_n ~=.
replace cpm_all = 0 if pmind == 0

replace pmamount = 0 if pmind == 0 & pmamount == .

****** Summary Statistics 

gen sampleok = !missing(hypscore, read, hhinc) & inrange(age, 1, 3) & mbio == 3 & cob == 1101 & momid ~=. & dadid ~= .

tab noid if sampleok
tab cohort if sampleok & noid == 1

keep if sampleok
keep cid age cage grade mage fage mcol fcol simean pmind weekday concent3 read num write pmamount hhinc cpm_n cpm_all numsib female border schoolmean day pmcpi hhinccpi siweekday siweekend hypscore concent1 concent2 concent4 concent5 cohort wave

xtset cid age
xtdescribe

bysort cid: gen n_obs = _N
sum age
local total_periods = r(max) - r(min) + 1

drop if n_obs < `total_periods'

drop n_obs

tab cohort

save "data_bp.dta", replace // Balanced panel

**** Consistent School hour

sum schoolmean if inrange(day, 1, 5) & schoolmean ~= . & age == 1, detail
gen schhr = 6.666667 if age == 1 & inrange(day, 1, 5) & schoolmean ~= .

sum schoolmean if inrange(day, 1, 5) & schoolmean ~= . & age == 2, detail
replace schhr = 6.783333 if age == 2 & inrange(day, 1, 5) & schoolmean ~= .

sum schoolmean if inrange(day, 1, 5) & schoolmean ~= . & age == 3, detail
replace schhr = 6.75 if age == 3 & inrange(day, 1, 5) & schoolmean ~= .

replace schhr = 0 if inrange(day, 6, 7) & inrange(age, 1, 3)

xtset cid age
sort cid age

keep if schhr ~= . & hhinc ~= 0

replace schhr = 60*schhr

xtset cid age
xtdescribe

* Step 1: Count the number of distinct age values per cid
bysort cid: egen num_periods = total(inlist(age, 1, 2, 3))

* Step 2: Keep only those cids that have observations for all 3 periods (t = 1, 2, and 3)
keep if num_periods == 3

* Step 3: Drop the helper variable
drop num_periods

keep if age ~= .

sort cid age 

***** Demographics (Aggregate)

replace pmcpi = 0 if pmamount == 0

sum pmind pmcpi cpm_all hhinccpi simean siweekday siweekend schoolmean read hypscore // Make simple tables of descriptive statistics. Put `i' in front of factor variables

sum pmcpi if pmind == 1

***** Main Variables disaggregated by child's age

dtable pmind pmcpi cpm_all hhinccpi simean siweekday siweekend schoolmean, by(age) // Make simple tables of descriptive statistics. Put `i' in front of factor variables

dtable pmcpi if pmind == 1, by(age)

replace simean = 60*simean

***** Heterogeneity in Child's SR

* Generate Initial SR variables
gen hyp_init = hypscore if age == 1
bysort cid (age): replace hyp_init = hyp_init[_n-1] if hyp_init[_n] == . & hyp_init[_n-1] ~= . & age > 1 

sum hypscore, detail
sum hyp_init, detail

* Define low and high SR children
gen lowreg = 1 if inrange(hyp_init, 6, 10) // Low Self-Regulation (Bottom 25% of attention capacitiy)
replace lowreg = 0 if inrange(hyp_init, 0, 1) // High Self-Regulation (Top 25% of attention capacitiy)

***** Income distribution and CPM Adoption

* Create income quintiles
xtile income_quartile = hhinc, nq(4)

dtable cpm_all if income_quartile == 1, by(age)
dtable cpm_all if income_quartile == 2, by(age)
dtable cpm_all if income_quartile == 3, by(age)
dtable cpm_all if income_quartile == 4, by(age)
dtable cpm_all, by(age)

*** Model and Counterfactuals Motivation 

* (1) Heterogeneity
foreach var of varlist hhinccpi read simean pmcpi {
    ttest `var', by(lowreg)
}

* (2) Are low-SR kids disproportionately in low-SES families?
ttest hhinccpi, by(cpm_all)

* (3) CPM receivers no difference in study time but it matters for no CPM
foreach var of varlist simean {
    ttest `var' if cpm_all == 0, by(lowreg)
}
foreach var of varlist simean {
    ttest `var' if cpm_all == 1, by(lowreg)
}

* (4) Need higher money to induce low SR children to comply with CPM contract
foreach var of varlist pmcpi {
    ttest `var' if lowreg == 1, by(cpm_all)
}
foreach var of varlist pmcpi {
    ttest `var' if lowreg == 0, by(cpm_all)
}

